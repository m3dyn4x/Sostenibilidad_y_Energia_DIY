# Environment variables for local development / production
# Copy this file to `.env` and replace values before running locally or deploying.

# Google Analytics (GA4) Measurement ID, e.g. G-XXXXXXXXXX
PUBLIC_GA_ID=

# Google AdSense client ID, e.g. ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_CLIENT=

# Optional: configure AdSense default slot ids via PUBLIC_AD_SLOT_DEFAULT
#PUBLIC_AD_SLOT_DEFAULT=
