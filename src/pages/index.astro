---
/*
  ================================================
  PÁGINA DE INICIO (HOME)
  ================================================
  
  Homepage principal con:
  - Hero section
  - Resumen de subnichos
  - Calculadora solar principal
  - CTA para newsletter
  
  ================================================
*/

import MainLayout from '@layouts/MainLayout.astro';
import SolarCalculator from '@components/Calculators/SolarCalculator.astro';
---

<MainLayout 
  title="Sostenibilidad y Energía DIY"
  description="Guías, calculadoras y recursos sobre energía solar, autoconsumo y sostenibilidad energética. Aprende a ahorrar en tu factura de luz.">
  
  <!-- HERO SECTION -->
  <section class="mb-16 md:mb-24 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-12 md:py-20 bg-gradient-to-br from-solar-50 via-white to-blue-50 rounded-2xl">
    <div class="max-w-3xl mx-auto text-center">
      <div class="mb-6">
        <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-amber-500 to-amber-700 bg-clip-text text-transparent mb-4">
          Energía Solar para Todos
        </h1>
        <p class="text-xl md:text-2xl text-gray-700">
          Aprende a instalar paneles solares, ahorra en tu factura y contribuye a un planeta más sostenible.
        </p>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="#subnichos" class="bg-amber-500 text-white px-6 py-3 rounded-lg hover:bg-amber-600 transition-colors font-semibold text-center decoration-none">
          Explorar Guías
        </a>
        <a href="#calculadora" class="btn-secondary text-center underline-none no-underline">
          Calcular mi Ahorro
        </a>
      </div>
    </div>
  </section>

  <!-- CALCULADORA PRINCIPAL -->
  <section id="calculadora" class="mb-20 scroll-mt-8">
    <div class="mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-2">Calcula tu Sistema Solar</h2>
      <p class="text-center text-gray-600 max-w-2xl mx-auto">
        Descubre cuántos paneles necesitas, la potencia instalada y cuánto ahorrarás en tu factura de luz.
      </p>
    </div>
    <SolarCalculator />
  </section>

  <!-- SUBNICHOS PRINCIPALES -->
  <section id="subnichos" class="mb-20 scroll-mt-8">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-2">Explora Nuestros Artículos</h2>
      <p class="text-center text-gray-600 max-w-2xl mx-auto">
        Soluciones específicas para cada tipo de necesidad energética.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Subniche 1: Kit Balcón -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">🏠</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Kit Solar Balcón</h3>
        <p class="text-gray-600 text-sm mb-4">
          Soluciones plug & play para inquilinos. Instala en tu balcón sin permisos complicados.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Para pisos y apartamentos</li>
          <li>✓ Sin instalación profesional</li>
          <li>✓ Fácil amortización</li>
        </ul>
        <a href="/blog/kit-solar-balcon-2026" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>

      <!-- Subniche 2: Off-Grid -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">🏔️</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Sistemas Off-Grid</h3>
        <p class="text-gray-600 text-sm mb-4">
          Energía independiente para casas aisladas, cabañas y fincas rurales sin red eléctrica.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Cálculo de baterías</li>
          <li>✓ Dimensionamiento preciso</li>
          <li>✓ Guías complejas</li>
        </ul>
        <a href="/blog/sistemas-off-grid-2026" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>

      <!-- Subniche 3: Bombeo Agrícola -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">🌾</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Bombeo Solar</h3>
        <p class="text-gray-600 text-sm mb-4">
          Sistemas de riego y bombeo sin gasoil. Para agricultores y ganaderos.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Alto ROI</li>
          <li>✓ Cero mantenimiento</li>
          <li>✓ Subvenciones disponibles</li>
        </ul>
        <a href="/blog/bombeo-solar-agricola" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>

      <!-- Subniche 4: Subsidios -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Subsidios y Desgravaciones</h3>
        <p class="text-gray-600 text-sm mb-4">
          Guías sobre ayudas, deducción IRPF, IBI y fondos europeos para tu instalación.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Deducción IRPF</li>
          <li>✓ Bonificación IBI</li>
          <li>✓ Fondos Next Generation</li>
        </ul>
        <a href="/blog/subsidios-2026" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>

      <!-- Subniche 5: Climatización -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">❄️</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Aerotermia + Solar</h3>
        <p class="text-gray-600 text-sm mb-4">
          Combina paneles solares con aerotermia para climatización 100% renovable.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Calefacción solar</li>
          <li>✓ Derivadores excedentes</li>
          <li>✓ Máximo ahorro</li>
        </ul>
        <a href="/blog/aerotermia-solar-2026" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>

      <!-- Subniche 6 (Bonus): Mantenimiento -->
      <div class="card hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-3">🔧</div>
        <h3 class="font-bold text-lg text-gray-900 mb-2">Mantenimiento y Reparación</h3>
        <p class="text-gray-600 text-sm mb-4">
          Soluciona errores de inversores, limpia paneles y optimiza tu generación.
        </p>
        <ul class="text-xs text-gray-700 space-y-1 mb-4">
          <li>✓ Troubleshooting</li>
          <li>✓ Limpieza sin daños</li>
          <li>✓ Rutina de mantenimiento</li>
        </ul>
        <a href="/blog/mantenimiento-reparacion-sistemas-solares-2026" class="btn-ghost text-sm">
          Leer guía →
        </a>
      </div>
    </div>
  </section>

  <!-- VENTAJAS DEL SITIO -->
  <section class="mb-20">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-2">¿Por qué confiar en nosotros?</h2>
      <p class="text-center text-gray-600 max-w-2xl mx-auto">
        Ofrecemos contenido verificado, herramientas prácticas y calculadoras educativas.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="text-5xl mb-4">📚</div>
        <h3 class="font-bold text-lg mb-2">Contenido Experto</h3>
        <p class="text-gray-600 text-sm">
          Redactado por profesionales del sector solar con experiencia real en instalaciones.
        </p>
      </div>

      <div class="text-center">
        <div class="text-5xl mb-4">🛠️</div>
        <h3 class="font-bold text-lg mb-2">Herramientas Prácticas</h3>
        <p class="text-gray-600 text-sm">
          Calculadoras interactivas que te ayudan a dimensionar tu sistema solar correctamente.
        </p>
      </div>

      <div class="text-center">
        <div class="text-5xl mb-4">📱</div>
        <h3 class="font-bold text-lg mb-2">100% Responsive</h3>
        <p class="text-gray-600 text-sm">
          Accede desde tu móvil, tablet o PC. Optimizado para la mejor experiencia.
        </p>
      </div>
    </div>
  </section>

</MainLayout>

