---
import MainLayout from '@layouts/MainLayout.astro';

const title = 'Página no encontrada';
const description = 'Lo sentimos, la página que buscas no existe. Regresa al inicio o explora nuestro blog.';
---

<MainLayout title={title} description={description} noindex>
  <div class="container-solar py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">404 — Página no encontrada</h1>
    <p class="text-gray-600 mb-8">Lo sentimos, la página que buscas no existe o fue movida.</p>
    <div class="flex justify-center gap-4">
      <a href="/" class="bg-amber-500 text-white px-6 py-3 rounded hover:bg-amber-600">Ir al inicio</a>
      <a href="/blog" class="border border-amber-500 text-amber-500 px-6 py-3 rounded hover:bg-amber-50">Explorar el blog</a>
    </div>
  </div>
</MainLayout>
