---
/*
  ================================================
  MAIN LAYOUT - TEMPLATE BASE DE TODAS LAS PÁGINAS
  ================================================
  
  Este layout proporciona:
  - Header con navegación
  - Footer
  - Meta tags (SEO)
  - Estilos globales
  - Estructura HTML base
  
  USO:
  ---
  import MainLayout from "@layouts/MainLayout.astro";
  ---
  
  <MainLayout 
    title="Mi página" 
    description="Descripción">
    <div>Mi contenido aquí</div>
  </MainLayout>
  
  ================================================
*/

import '@styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean; // Para páginas que no quieres en Google
}

const {
  title = 'Sostenibilidad y Energía DIY',
  description = 'Guías, calculadoras y recursos sobre energía solar y autoconsumo',
  image = 'https://via.placeholder.com/1200x630',
  noindex = false,
} = Astro.props;

const siteTitle = title === 'Sostenibilidad y Energía DIY' ? title : `${title} | Sostenibilidad y Energía DIY`;
const currentUrl = Astro.url.href;
const GA_ID = import.meta.env.PUBLIC_GA_ID ?? null;
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? null;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Meta tags base -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f59e0b" />
    
    <!-- Prevent indexing en desarrollo -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:type" content="website" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Favicon (placeholder) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Analytics (GA4) - activa estableciendo `PUBLIC_GA_ID` en .env -->
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${GA_ID}');`}></script>
      </>
    )}

    <!-- AdSense - activa estableciendo `PUBLIC_ADSENSE_CLIENT` en .env -->
    {ADSENSE_CLIENT && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`} crossorigin="anonymous"></script>
    )}
    
    <title>{siteTitle}</title>
  </head>

  <body class="flex flex-col min-h-screen">
    <!-- Header / Navegación -->
    <header class="bg-white border-b border-gray-200">
      <nav class="container-solar py-4 flex justify-between items-center">
        <a href="/" class="flex items-center gap-2">
          <span class="text-2xl font-bold text-amber-500">☀️</span>
          <span class="font-bold text-lg text-gray-900">Energía DIY</span>
        </a>
        
        <ul class="hidden md:flex gap-6 text-sm font-medium">
          <li><a href="/" class="text-gray-700 hover:text-amber-500">Inicio</a></li>
          <li><a href="#subnichos" class="text-gray-700 hover:text-amber-500">Subnichos</a></li>
          <li><a href="/blog" class="text-gray-700 hover:text-amber-500">Blog</a></li>
          <li><a href="#herramientas" class="text-gray-700 hover:text-amber-500">Herramientas</a></li>
        </ul>
        
        <!-- Mobile menu button -->
        <button class="md:hidden p-2 hover:bg-gray-100 rounded-lg">
          <span class="text-2xl">≡</span>
        </button>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1 container-solar py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-16">
      <div class="container-solar py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Sobre el sitio -->
          <div>
            <h3 class="font-bold text-lg mb-4">Sobre Nosotros</h3>
            <p class="text-gray-400 text-sm">
              Guías y herramientas para optimizar tu consumo de energía solar y construir un futuro sostenible.
            </p>
          </div>
          
          <!-- Links principales -->
          <div>
            <h3 class="font-bold text-lg mb-4">Recursos</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/" class="hover:text-amber-500">Inicio</a></li>
              <li><a href="/blog" class="hover:text-amber-500">Blog</a></li>
              <li><a href="#tools" class="hover:text-amber-500">Calculadoras</a></li>
            </ul>
          </div>
          
          <!-- Legal -->
          <div>
            <h3 class="font-bold text-lg mb-4">Legal</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="#privacy" class="hover:text-amber-500">Privacidad</a></li>
              <li><a href="#terms" class="hover:text-amber-500">Términos</a></li>
              <li><a href="#cookies" class="hover:text-amber-500">Cookies</a></li>
            </ul>
          </div>
          
          <!-- Newsletter removed by request: show follow links instead -->
          <div>
            <h3 class="font-bold text-lg mb-4">Sigue nuestras guías</h3>
            <p class="text-gray-400 text-sm">Encontrarás nuevas guías y herramientas en el <a href="/blog" class="underline hover:text-amber-300">blog</a> o en nuestro feed.</p>
          </div>
        </div>
        
        <!-- Copyright -->
        <div class="border-t border-gray-800 pt-8">
          <p class="text-center text-gray-400 text-sm">
            © 2026 Sostenibilidad y Energía DIY. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>
    <!-- Global image error handler: sustituye con un placeholder si falla la carga -->
    <script>
      document.addEventListener('error', function(e) {
        const t = e.target as HTMLImageElement | null;
        if (t && t.tagName === 'IMG' && !(t.dataset as any).fallback) {
          (t.dataset as any).fallback = true;
          t.src = 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR4nGMAAQAABQABDQottAAAAABJRU5ErkJggg==';
        }
      }, true);
    </script>
  </body>
</html>
