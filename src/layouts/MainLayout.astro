---
/*
  ================================================
  MAIN LAYOUT - TEMPLATE BASE DE TODAS LAS PÁGINAS
  ================================================

  Este layout proporciona:
  - Header con navegación
  - Footer
  - Meta tags (SEO)
  - Estilos globales
  - Estructura HTML base
  - Soporte para i18n y cookies

  USO:
  ---
  import MainLayout from "@layouts/MainLayout.astro";
  ---

  <MainLayout
    title="Mi página"
    description="Descripción">
    <div>Mi contenido aquí</div>
  </MainLayout>

  ================================================
*/

import '@styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean; // Para páginas que no quieres en Google
}

const {
  title = 'Energía Solar DIY | Paneles Solares | Autoconsumo | Calculadora Solar 2026',
  description = 'Calculadora solar gratuita para autoconsumo. Guías instalación paneles solares, subsidios fotovoltaicos 2026, ahorro factura luz. Energía renovable DIY. Aprende a ahorrar con solar.',
  image = 'https://via.placeholder.com/1200x630',
  noindex = false,
} = Astro.props;

const siteTitle = title === 'Sostenibilidad y Energía DIY' ? title : `${title} | Sostenibilidad y Energía DIY`;
const currentUrl = Astro.url.href;
const GA_ID = import.meta.env.PUBLIC_GA_ID ?? null;
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? null;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Meta tags base -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="energía solar, paneles solares, autoconsumo, fotovoltaica, calculadora solar, subsidios solares 2026, ahorro energía, solar DIY, instalación solar, bombeo solar, aerotermia solar" />
    <meta name="author" content="Energía Solar DIY" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="language" content="Spanish" />
    <meta name="theme-color" content="#f59e0b" />
    <meta name="msapplication-TileColor" content="#f59e0b" />
    <link rel="canonical" href={currentUrl} />
    
    <!-- Structured Data (JSON-LD) para SEO -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Energía Solar DIY",
      "description": "Calculadora solar gratuita para autoconsumo. Guías instalación paneles solares, subsidios fotovoltaicos 2026, ahorro factura luz.",
      "url": {currentUrl},
      "publisher": {
        "@type": "Organization",
        "name": "Energía Solar DIY",
        "logo": {
          "@type": "ImageObject",
          "url": "https://via.placeholder.com/200x60"
        }
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {currentUrl} + "/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      },
      "keywords": ["energía solar", "paneles solares", "autoconsumo", "fotovoltaica", "calculadora solar", "subsidios solares", "ahorro energía", "solar DIY"]
    }
    </script>
    
    <!-- Prevent indexing en desarrollo -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:type" content="website" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Favicon (placeholder) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Analytics (GA4) - activa estableciendo `PUBLIC_GA_ID` en .env -->
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KSL8JPYYE7"></script>
    <script lang="ts">
      declare global {
        interface Window {
          dataLayer: any[];
          gtag: (...args: any[]) => void;
        }
      }
      
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) { window.dataLayer.push(args); }
      gtag('js', new Date());
      gtag('config', 'G-KSL8JPYYE7');
    </script>

    <meta name="google-adsense-account" content="ca-pub-6773309674115541">
    
    <title>{siteTitle}</title>
  </head>

  <body class="flex flex-col min-h-screen">
    <!-- Header / Navegación -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <nav class="container-solar py-4 flex justify-between items-center">
        <a href="/" class="flex items-center gap-2">
          <span class="text-2xl font-bold text-amber-500">☀️</span>
          <span class="font-bold text-lg text-gray-900">Energía DIY</span>
        </a>

        <div class="flex items-center gap-4">
          <ul class="hidden md:flex gap-6 text-sm font-medium">
            <li><a href="/" class="text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Inicio</a></li>
            <li><a href="/#subnichos" class="text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Subnichos</a></li>
            <li><a href="/blog" class="text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Blog</a></li>
            <li><a href="/#calculadora" class="text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Herramientas</a></li>
          </ul>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg" aria-label="Toggle menu" aria-expanded="false">
            <span class="text-2xl">≡</span>
          </button>
        </div>
      </nav>

      <!-- Mobile navigation menu -->
      <nav id="mobile-menu" class="hidden md:hidden bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
        <div class="container-solar py-4">
          <ul class="space-y-4 text-sm font-medium">
            <li><a href="/" class="block text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Inicio</a></li>
            <li><a href="/#subnichos" class="block text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Subnichos</a></li>
            <li><a href="/blog" class="block text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Blog</a></li>
            <li><a href="/#calculadora" class="block text-gray-700 dark:text-gray-300 hover:text-amber-500 dark:hover:text-amber-400">Herramientas</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1 container-solar py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-16">
      <div class="container-solar py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Sobre el sitio -->
          <div>
            <h3 class="font-bold text-lg mb-4 text-white">Sobre nosotros</h3>
            <p class="text-gray-400 text-sm">
              Plataforma dedicada a la energía solar y la sostenibilidad. Aprende cómo generar tu propia energía con paneles solares y reduce tu factura de electricidad.
            </p>
          </div>

          <!-- Links principales -->
          <div>
            <h3 class="font-bold text-lg mb-4">Blog</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/" class="hover:text-amber-500">Inicio</a></li>
              <li><a href="/blog" class="hover:text-amber-500">Blog</a></li>
              <li><a href="/#calculadora" class="hover:text-amber-500">Calculadora</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="font-bold text-lg mb-4">Legal</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/privacidad" class="hover:text-amber-500">Privacidad</a></li>
              <li><a href="/terminos" class="hover:text-amber-500">Términos</a></li>
              <li><a href="/politica-cookies" class="hover:text-amber-500">Cookies</a></li>
            </ul>
          </div>

          <!-- Newsletter removed by request: show follow links instead -->
          <div>
            <h3 class="font-bold text-lg mb-4">Sigue nuestras guías</h3>
            <p class="text-gray-400 text-sm">Encontrarás nuevas guías y herramientas en el <a href="/blog" class="underline hover:text-amber-300">blog</a> o en nuestro feed.</p>
          </div>
        </div>

        <!-- Copyright -->
        <div class="border-t border-gray-800 pt-8">
          <p class="text-center text-gray-400 text-sm">
            © 2026 Energía Solar DIY. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script>
      function initMobileMenu(): void {
        const menuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;

        if (!menuBtn || !mobileMenu) {
          console.log('[Mobile Menu] Button or menu not found');
          return;
        }

        menuBtn.addEventListener('click', function() {
          const isHidden = mobileMenu.classList.contains('hidden');
          
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            menuBtn.setAttribute('aria-expanded', 'true');
          } else {
            mobileMenu.classList.add('hidden');
            menuBtn.setAttribute('aria-expanded', 'false');
          }
        });

        // Close menu when clicking on a link
        const menuLinks = mobileMenu.querySelectorAll('a');
        menuLinks.forEach(link => {
          link.addEventListener('click', function() {
            mobileMenu.classList.add('hidden');
            menuBtn.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // Run on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileMenu);
      } else {
        initMobileMenu();
      }
    </script>

    <!-- Global image error handler -->
    <script>
      document.addEventListener('error', function(e) {
        const t = e.target as HTMLImageElement | null;
        if (t && t.tagName === 'IMG' && !(t.dataset as any).fallback) {
          (t.dataset as any).fallback = true;
          t.src = 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR4nGMAAQAABQABDQottAAAAABJRU5ErkJggg==';
        }
      }, true);
    </script>
  </body>
</html>
