---
/*
  ================================================
  BLOG LAYOUT - TEMPLATE PARA ARTÍCULOS
  ================================================
  
  Layout especializado para artículos del blog con:
  - Metadata de artículo (fecha, autor, etc.)
  - Tabla de contenidos
  - Breadcrumbs
  - Meta tags locales
  
  USO:
  ---
  import BlogLayout from "@layouts/BlogLayout.astro";
  ---
  
  <BlogLayout 
    title="Mi artículo"
    {...metadata}>
    <div>Mi contenido MDX aquí</div>
  </BlogLayout>
  
  ================================================
*/

import MainLayout from './MainLayout.astro';
import { generateArticleSchema } from '@utils/seo';
import AdSlot from '@components/AdSlot.astro';

interface Props {
  title: string;
  description: string;
  author?: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: string;
  category?: string;
  readingTime?: number;
}

const {
  title,
  description,
  author = 'Admin',
  pubDate,
  updatedDate,
  image = 'https://via.placeholder.com/1200x630',
  category = 'general',
  readingTime = 5,
} = Astro.props;

// Schema JSON-LD para el artículo
const schema = generateArticleSchema({
  title,
  description,
  image,
  author,
  publishedDate: pubDate,
  url: Astro.url.href,
});
---

<MainLayout title={title} description={description} image={image}>
  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <!-- Breadcrumbs -->
  <div class="mb-8 text-sm">
    <a href="/" class="text-amber-500 hover:underline">Inicio</a>
    <span class="mx-2 text-gray-400">/</span>
    <a href="/blog" class="text-amber-500 hover:underline">Blog</a>
    <span class="mx-2 text-gray-400">/</span>
    <span class="text-gray-700">{title}</span>
  </div>

  <!-- Article header -->
  <article class="max-w-4xl mx-auto">
    <!-- Categoría -->
    <div class="mb-6">
      <span class="inline-block bg-gradient-to-r from-amber-100 to-amber-50 text-amber-800 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider shadow-sm">
        {category}
      </span>
    </div>

    <!-- Título -->
    <h1 class="text-5xl md:text-6xl font-black mb-6 text-gray-900 leading-tight">{title}</h1>
    
    <!-- Metadata del artículo -->
    <div class="flex flex-col md:flex-row gap-6 md:gap-10 text-sm text-gray-600 mb-10 pb-10 border-b-2 border-gray-200">
      <div class="flex items-center gap-2">
        <span class="inline-block w-10 h-10 rounded-full bg-amber-100 text-amber-600 font-bold flex items-center justify-center text-lg">
          {author.charAt(0)}
        </span>
        <div>
          <p class="font-semibold text-gray-800">{author}</p>
          <p class="text-xs text-gray-500">Autor</p>
        </div>
      </div>
      
      <div class="flex items-center gap-2 border-l border-gray-300 pl-6">
        <span class="text-2xl">📅</span>
        <div>
          <p class="font-semibold text-gray-800">{pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          {updatedDate && (
            <p class="text-xs text-gray-500">Actualizado: {updatedDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          )}
        </div>
      </div>
      
      <div class="flex items-center gap-2 border-l border-gray-300 pl-6">
        <span class="text-2xl">⏱</span>
        <div>
          <p class="font-semibold text-gray-800">{readingTime} min</p>
          <p class="text-xs text-gray-500">de lectura</p>
        </div>
      </div>
    </div>

    <!-- Imagen destacada -->
    {image && (
      <figure class="mb-12">
        <img
          src={image}
          alt={title}
          class="w-full h-auto max-h-96 object-cover rounded-xl shadow-xl border border-gray-200 transition-transform duration-300 hover:scale-105"
        />
        <figcaption class="text-center text-sm text-gray-600 mt-3 italic">Imagen destacada: {title}</figcaption>
      </figure>
    )}

    <!-- Descripción -->
    <p class="text-xl text-gray-700 mb-10 leading-relaxed font-semibold bg-gradient-to-r from-amber-50 to-transparent p-6 rounded-lg border-l-4 border-amber-400">
      {description}
    </p>

    <!-- Ad slot after description -->
    <div class="mb-8">
      <AdSlot slot={import.meta.env.PUBLIC_AD_SLOT_DEFAULT ?? '1234567890'} class="my-6" />
    </div>

    <!-- Contenido principal -->
    <div class="prose prose-lg max-w-none mb-16">
      <!-- Aquí va el contenido del slot -->
      <slot />
    </div>

    <!-- CTA / Siguiente artículo (newsletter removed) -->
    <div class="border-t border-gray-200 pt-8 mt-8">
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-8 text-center">
        <h3 class="font-bold text-xl mb-2">¿Quieres aprender más sobre energía solar?</h3>
        <p class="text-gray-700 mb-4">
          Consulta más guías en nuestro <a href="/blog" class="font-medium underline">blog</a> o sigue el feed para actualizaciones.
        </p>
        <a href="/blog" class="inline-block bg-amber-500 text-white px-6 py-2 rounded font-medium hover:bg-amber-600">Ir al blog</a>
      </div>
    </div>
  </article>
</MainLayout>

<style>
  /* Estilos específicos para el contenido MDX */
  :global(.prose h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-size: 1.875rem;
    font-weight: 700;
    color: #111827;
    border-bottom: 3px solid #fbbf24;
    padding-bottom: 0.5rem;
  }
  
  :global(.prose h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.875rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
  }
  
  :global(.prose h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #374151;
  }
  
  :global(.prose p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    font-size: 1.0625rem;
    color: #374151;
  }
  
  :global(.prose ul, .prose ol) {
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
  }
  
  :global(.prose li) {
    margin-bottom: 0.625rem;
    line-height: 1.65;
    color: #374151;
  }
  
  :global(.prose blockquote) {
    border-left: 4px solid #f59e0b;
    padding-left: 1.5rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    font-style: italic;
    color: #6b7280;
    margin: 1.5rem 0;
    background-color: #fffbeb;
    border-radius: 0.25rem;
  }
  
  :global(.prose code) {
    background-color: #f3f4f6;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9375rem;
    color: #d97706;
    font-weight: 500;
  }
  
  :global(.prose pre) {
    background-color: #1f2937;
    color: #f3f4f6;
    padding: 1.5rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid #374151;
  }
  
  :global(.prose pre code) {
    background-color: transparent;
    padding: 0;
    color: #f3f4f6;
  }
  
  :global(.prose strong) {
    font-weight: 700;
    color: #1f2937;
  }
  
  :global(.prose em) {
    font-style: italic;
    color: #6b7280;
  }
  
  /* Table styling */
  :global(.prose table) {
    margin: 1.5rem 0;
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  
  :global(.prose thead) {
    background-color: #f9fafb;
    border-bottom: 2px solid #e5e7eb;
  }
  
  :global(.prose th) {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #111827;
  }
  
  :global(.prose td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }
  
  :global(.prose tbody tr:hover) {
    background-color: #f9fafb;
  }
  
  /* Links */
  :global(.prose a) {
    color: #f59e0b;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
  }
  
  :global(.prose a:hover) {
    color: #d97706;
    border-bottom-color: #d97706;
  }
  
  /* Images */
  :global(.prose img) {
    margin: 1.5rem 0;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  
  /* Main article container styling */
  :global(article) {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  }
</style>
