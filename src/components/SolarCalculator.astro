<section class="p-6 bg-white rounded-xl shadow-lg border border-slate-100 max-w-2xl mx-auto my-10">
  <h2 class="text-2xl font-bold text-slate-800 mb-6 text-center">Calculadora de Autoconsumo Solar</h2>

  <form id="solarForm" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="consumo" class="block text-sm font-medium text-slate-600 mb-1">Consumo anual (kWh)</label>
        <input required type="number" id="consumo" min="100" step="1" placeholder="Ej: 3500"
          class="w-full p-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-yellow-500 outline-none" />
      </div>
      <div>
        <label for="hsp" class="block text-sm font-medium text-slate-600 mb-1">Horas sol pico (HSP)</label>
        <input required type="number" id="hsp" step="0.1" min="2" max="7" placeholder="Ej: 4.5"
          class="w-full p-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-yellow-500 outline-none" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="precio" class="block text-sm font-medium text-slate-600 mb-1">Precio electricidad (€ / kWh)</label>
        <input required type="number" id="precio" step="0.01" min="0.01" placeholder="Ej: 0.22"
          class="w-full p-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-yellow-500 outline-none" />
      </div>
      <div>
        <label for="orientacion" class="block text-sm font-medium text-slate-600 mb-1">Orientación</label>
        <select id="orientacion" class="w-full p-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-yellow-500 outline-none">
          <option value="sur" selected>Sur</option>
          <option value="suroeste">Suroeste</option>
          <option value="sureste">Sureste</option>
          <option value="este">Este</option>
          <option value="oeste">Oeste</option>
        </select>
      </div>
    </div>

    <div>
      <label for="inclinacion" class="block text-sm font-medium text-slate-600 mb-1">Inclinación (º)</label>
      <input type="number" id="inclinacion" step="1" min="0" max="90" placeholder="Ej: 25"
        class="w-full p-2 border border-slate-300 rounded-md focus:ring-2 focus:ring-yellow-500 outline-none" />
      <p class="text-xs text-slate-500 mt-1">Recomendado: igual a tu latitud</p>
    </div>

    <button id="calcBtn" type="submit"
      class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-3 rounded-md transition-colors duration-200">
      Calcular</button>
  </form>

  <div id="results" class="hidden mt-8 bg-slate-50 p-6 rounded-lg shadow-inner">
    <h3 class="text-lg font-semibold text-slate-800 mb-4 text-center">Resultados estimados</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-center">
      <div>
        <span class="block text-xs uppercase text-slate-500 font-bold">Paneles necesarios</span>
        <span id="resPaneles" class="text-2xl font-black text-slate-800">-</span>
      </div>
      <div>
        <span class="block text-xs uppercase text-slate-500 font-bold">Potencia (kWp)</span>
        <span id="resPotencia" class="text-2xl font-black text-slate-800">-</span>
      </div>
      <div>
        <span class="block text-xs uppercase text-slate-500 font-bold">Inversión estimada</span>
        <span id="resCoste" class="text-2xl font-black text-green-600">-</span>
      </div>
      <div>
        <span class="block text-xs uppercase text-slate-500 font-bold">Ahorro anual</span>
        <span id="resAhorro" class="text-2xl font-black text-green-600">-</span>
      </div>
      <div class="sm:col-span-2">
        <span class="block text-xs uppercase text-slate-500 font-bold">Tiempo de amortización</span>
        <span id="resTiempo" class="text-2xl font-black text-blue-600">-</span>
      </div>
    </div>
    <p class="mt-4 text-xs text-slate-500">Los resultados son aproximados. Ajusta variables como orientación e inclinación para mayor precisión.</p>
  </div>
</section>

<script>
  const form = document.getElementById('solarForm');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const consumo = parseFloat((document.getElementById('consumo') as HTMLInputElement).value);
    const hsp = parseFloat((document.getElementById('hsp') as HTMLInputElement).value);
    const precio = parseFloat((document.getElementById('precio') as HTMLInputElement).value);
    const orientacion = (document.getElementById('orientacion') as HTMLSelectElement).value as any;
    const inclinacionInput = document.getElementById('inclinacion') as HTMLInputElement;
    const inclinacion = inclinacionInput.value ? parseFloat(inclinacionInput.value) : undefined;

    if (consumo <= 0 || hsp <= 0 || precio <= 0) {
      alert('Introduce todos los campos obligatorios correctamente');
      return;
    }

    try {
      const resp = await fetch('/api/calculate-solar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ consumoAnual: consumo, horasSol: hsp, precioKwh: precio, orientacion, inclinacion })
      });
      const data = await resp.json();
      if (!data.success) throw new Error(data.error || 'Error');

      const r = data.data;
      document.getElementById('resPaneles')!.innerText = r.paneles.toString();
      document.getElementById('resPotencia')!.innerText = r.potenciaKwp.toFixed(2);
      document.getElementById('resCoste')!.innerText = `${Math.round(r.costoEstimado.total)}€`;
      document.getElementById('resAhorro')!.innerText = `${Math.round(r.ahorroAnual)}€`;
      document.getElementById('resTiempo')!.innerText = `${r.amortizacion.toFixed(1)} años`;
      document.getElementById('results')!.classList.remove('hidden');
    } catch (err) {
      console.error('calculadora error', err);
      alert('No se pudo calcular. Revisa los datos y vuelve a intentar.');
    }
  });
</script>